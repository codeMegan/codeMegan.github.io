    <title>“从心学医学”第6期：心的一尖一底两面三缘四沟</title>
    <link href="/2026/04/28/%E2%80%9C%E4%BB%8E%E5%BF%83%E5%AD%A6%E5%8C%BB%E5%AD%A6%E2%80%9D%E7%AC%AC6%E6%9C%9F%EF%BC%9A%E5%BF%83%E7%9A%84%E4%B8%80%E5%B0%96%E4%B8%80%E5%BA%95%E4%B8%A4%E9%9D%A2%E4%B8%89%E7%BC%98%E5%9B%9B%E6%B2%9F/"/>
    <url>/2026/04/28/%E2%80%9C%E4%BB%8E%E5%BF%83%E5%AD%A6%E5%8C%BB%E5%AD%A6%E2%80%9D%E7%AC%AC6%E6%9C%9F%EF%BC%9A%E5%BF%83%E7%9A%84%E4%B8%80%E5%B0%96%E4%B8%80%E5%BA%95%E4%B8%A4%E9%9D%A2%E4%B8%89%E7%BC%98%E5%9B%9B%E6%B2%9F/</url>
    
    <content type="html"><![CDATA[<h3 id="一尖"><a href="#一尖" class="headerlink" title="一尖"></a>一尖</h3><h3 id="一底"><a href="#一底" class="headerlink" title="一底"></a>一底</h3><h3 id="两面"><a href="#两面" class="headerlink" title="两面"></a>两面</h3><h4 id="胸肋面"><a href="#胸肋面" class="headerlink" title="胸肋面"></a>胸肋面</h4><h4 id="膈面"><a href="#膈面" class="headerlink" title="膈面"></a>膈面</h4><h3 id="三缘"><a href="#三缘" class="headerlink" title="三缘"></a>三缘</h3><h4 id="下缘"><a href="#下缘" class="headerlink" title="下缘"></a>下缘</h4><h4 id="左缘"><a href="#左缘" class="headerlink" title="左缘"></a>左缘</h4><h4 id="右缘"><a href="#右缘" class="headerlink" title="右缘"></a>右缘</h4><h3 id="四沟"><a href="#四沟" class="headerlink" title="四沟"></a>四沟</h3><h4 id="冠状沟"><a href="#冠状沟" class="headerlink" title="冠状沟"></a>冠状沟</h4><h4 id="前室间沟"><a href="#前室间沟" class="headerlink" title="前室间沟"></a>前室间沟</h4><h4 id="后室间沟"><a href="#后室间沟" class="headerlink" title="后室间沟"></a>后室间沟</h4><h4 id="房间沟"><a href="#房间沟" class="headerlink" title="房间沟"></a>房间沟</h4>]]></content>
    
    
